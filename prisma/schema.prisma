// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Song {
  id               Int      @id @default(autoincrement())
  slug             String   @unique // URL용 고유 식별자 (예: discord, tb-h)
  title            String
  albumName        String   // 앨범별 그룹화
  youtubeId        String   // 기준 유튜브 영상 ID
  lyrics           Json     // LyricLine[]
  hasOfficialCheer Boolean  @default(false)
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
