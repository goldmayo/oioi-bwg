{
  "name": "cheer-rock-crab",
  "version": "0.2.1",
  "private": true,
  "scripts": {
    "dev": "vinext dev",
    "build": "npx wrangler types && vinext build",
    "build:staging": "npx wrangler types && env-cmd -f .env.staging vinext build",
    "build:prod": "npx wrangler types && env-cmd -f .env.production vinext build",
    "start": "npx wrangler dev",
    "start:staging": "env-cmd -f .env.staging npx wrangler dev --env staging",
    "start:prod": "env-cmd -f .env.production npx wrangler dev",
    "dev:next": "next dev",
    "build:next": "next build",
    "start:next": "next start",
    "lint": "eslint",
    "type-check": "npx wrangler types && tsc --noEmit",
    "prepare": "husky",
    "db:seed": "tsx src/libs/db/drizzle/seed.ts",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "deploy": "npx wrangler types && vinext deploy",
    "deploy:staging": "npx wrangler types && env-cmd -f .env.staging vinext deploy --env staging",
    "deploy:prod": "npx wrangler types && env-cmd -f .env.production vinext deploy",
    "release": "release-it"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/cloudflare": "^10.42.0",
    "@sentry/nextjs": "^10.42.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "gsap": "^3.14.2",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.8",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.7.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@release-it/conventional-changelog": "^10.0.5",
    "@sentry/vite-plugin": "^5.1.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-rsc": "^0.5.21",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "env-cmd": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-server-dom-webpack": "^19.2.4",
    "release-it": "^19.2.4",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vinext": "^0.0.28",
    "vite": "^7.3.1",
    "wrangler": "^4.71.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "type": "module"
}
